/* This is just an Example to show how the code functions */
fn RandomInt(i32 end) -> i32
{
	return (Random() * end) as i32;
}

fn RandomInt(i32 start, i32 end) -> i32
{
	if (start > end)
	{
		i32 tmp = start;
		start = end;
		end = tmp;
	}

	i32 gap = end - start;
	return (Random() * gap + start) as i32;
}

fn Randomize(&mut i32 t)
{
	t = RandomInt(0,100);
}

fn Main() -> bool
{
	i32 t;

	i32[] tab = new i32[5];
	tab[0] = 5;
	
	loop
	{
		Randomize(&mut t);
		if ( t % 2 == 0)
		{
			Printf("The number {t} is Even.\n");
			continue;
		}

		if (t == 5) break;
		
		Printf("The number {t} is Odd.\n");
	}


	Printf("End\n");

	let x = 7;

	if ( 5 < x && x < 10)
		Printf("{x} is bitween 5 and 10\n");
	
	if ( 5 < x < 10)
		Printf("{x} is bitween 5 and 10\n");


}
