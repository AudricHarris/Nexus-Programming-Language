/* This is the nexus Programming language                                  */
/* This prototype code demonstrates the syntax of the language             */
/* it's a low level multi-paradigm language similar to CPP                 */
/* it's in the same family of languages as rust being a ownership language */

/* This is just an Example to show how the code functions */
fn RandomInt(i32 end) -> i32
{
	return (Random() * end) as i32;
}

fn RandomInt(i32 start, i32 end) -> i32
{
	if (start > end)
	{
		i32 tmp = start;
		start = end;
		end = tmp;
	}

	i32 gap = end - start;
	return (Random() * gap + start) as i32;
}

fn Randomize(&mut i32 t)
{
	t = RandomInt(0,100);
}

fn Main() -> bool
{
	i32 t;

	loop
	{
		Randomize(&mut t);
		if ( t % 2 == 0)
		{
			Printf("The number {t} is Even.\n");
			continue;
		}

		if (t == 5) break;
		
		Printf("The number {t} is Odd.\n");
	}


	Printf("Last Message : {tab}\n");

	let x = RandomInt(10, 20);
	let y = 15;
	
	if ( 5 < x && x < y)
		Printf("{x} is bitween 5 and 15\n");
	else
		Print("Non valid : 1");
	
	if ( 5 < y < x)
		Printf("15 is bitween 5 and {x}\n");
	else
		Print("Non valid : 2");


}
