/!import "test"; /* Imports all
import "test::Borrow"; /* imports all method with Borrow
import "test::Borrow(&i32)"; /* imports all method with that definition
!/
Borrow(&i32 ex, &f32 ok)
{
	ex = ex * 5 + 4;
	ok = ok * 5.0;
}

Copy(i32 ex)
{
	ex = ex * 5 + 4;	
}

Main() -> bool
{
	i32 ex = 8;
	f32 ex2 = 4.0;
	Borrow(ex, ex2);
	Printf("Borrow  : {ex} & {ex2}\n");

	return true;
}
